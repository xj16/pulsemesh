%%% rebar3 build configuration for the PulseMesh fabric node.
%%% The fabric is the persistent-connection layer: it holds live client
%%% WebSocket connections, tracks presence in supervised gen_servers, and
%%% consumes committed events from RabbitMQ to fan them out per channel.

{erl_opts, [debug_info, warnings_as_errors]}.

%% Dependency versions are chosen so the whole transitive graph resolves with
%% NO shared-dependency conflicts under rebar3's classic resolver:
%%   * cowboy 2.12.0 pins cowlib 2.13.0 and ranch 1.8.0 with EXACT versions
%%     (cowboy >= 2.13 switched to compound ">= x and < y" ranges that the
%%     classic resolver rejects — hence 2.12.0).
%%   * amqp_client 3.12.14 -> rabbit_common 3.12.14 pulls in neither cowlib
%%     nor ranch, so there is nothing to clash with cowboy's pins.
%% This keeps `rebar3 compile` deterministic on clean CI checkouts.
{deps, [
  %% HTTP + WebSocket server
  {cowboy, "2.12.0"},
  %% AMQP 0-9-1 client for RabbitMQ
  {amqp_client, "3.12.14"},
  %% JSON codec
  {jsx, "3.1.0"}
]}.

{shell, [
  {config, "config/sys.config"},
  {apps, [pulsemesh_fabric]}
]}.

{relx, [
  {release, {pulsemesh_fabric, "0.1.0"}, [pulsemesh_fabric, sasl]},
  {mode, dev},
  %% Dev releases fall back to the env defaults in the .app.src (no sys.config
  %% here, which keeps it from conflicting with the prod profile's
  %% sys.config.src). `rebar3 shell` still loads config/sys.config via the
  %% {shell, ...} stanza above.
  {vm_args, "config/vm.args"}
]}.

{profiles, [
  {prod, [
    {relx, [
      {mode, prod},
      {include_erts, true},
      %% Use the env-substituting config in release builds so docker-compose
      %% can inject broker URIs at container start (RELX_REPLACE_OS_VARS=true).
      {sys_config_src, "config/sys.config.src"},
      {vm_args, "config/vm.args"}
    ]}
  ]},
  {test, [
    {erl_opts, [debug_info, nowarn_export_all]}
  ]}
]}.

{eunit_opts, [verbose]}.

{dialyzer, [
  {warnings, [unmatched_returns, error_handling]}
]}.
