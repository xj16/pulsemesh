%%% Runtime configuration for the PulseMesh fabric release.
%%% Values fall back to the app.src defaults; override via env for docker.
[
  {pulsemesh_fabric, [
    {http_port, 8090},
    {amqp_uri, "amqp://guest:guest@localhost:5672"},
    {amqp_exchange, <<"pulsemesh.events">>}
  ]},

  {kernel, [
    {logger_level, info},
    {logger, [
      {handler, default, logger_std_h,
        #{formatter => {logger_formatter,
                        #{template => [time, " ", level, " ", msg, "\n"]}}}}
    ]}
  ]}
].
